# Required: Secret token for the /api/publish-article endpoint (n8n integration)
PUBLISH_TOKEN=your-secret-token-here

# Required for Vercel Blob (auto-populated when you add Blob storage in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Optional: Override the site URL for sitemap generation
SITE_URL=https://spark-maklerservice.com
